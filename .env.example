POSTGRES_DB=clinic_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

POSTGRES_PORT=5433

SERVER_PORT=8765

DB_HBM2DDL=update

JWT_SECRET=change-this-jwt-secret-at-least-32-bytes-long

MAIL_ENABLED=false
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_AUTH=true
MAIL_USERNAME=your-mail@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=no-reply@clinic.local
MAIL_FROM_NAME=Клиника / Запись к врачу

REMINDER_ENABLED=true
REMINDER_SCAN_PERIOD_SECONDS=60
REMINDER_LEAD_HOURS=24
REMINDER_WORKER_THREADS=2

BOOTSTRAP_CREATE_DEFAULT_ADMIN=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@clinic.local
BOOTSTRAP_ADMIN_FULL_NAME=Администратор системы
BOOTSTRAP_SEED_DEFAULT_DATA=true
BOOTSTRAP_SEED_RESOURCE=db/seed.sql
BOOTSTRAP_SEED_USER_PASSWORD=password
